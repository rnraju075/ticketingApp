{
  "compilerOptions": {
    "target": "ES2022",

    "module": "commonjs",

    "moduleResolution": "node",

    "rootDir": "./",

    "outDir": "dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "isolatedModules": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src", "jest.config.ts"]
}