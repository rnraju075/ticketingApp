{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",

    "sourceMap": true,
    "declaration": true,

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*"]
}